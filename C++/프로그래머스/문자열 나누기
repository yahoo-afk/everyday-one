#include <string>
#include <vector>

using namespace std;

int solution(string s) {
    int answer = 0;
   char first = s[0];
    int dif =0;
    int same =0;
   for(int i=0; i<s.size(); ++i)
   {
       if(same  == 0 )
       {
           first = s[i];
       }
       if(first == s[i])
       {
           same++;
       }
       else
       {
           dif++;
       }
       if(same == dif)
       {
           answer++;
           same =0;
           dif = 0;
       }
       
   }  
    if(same != 0)
    {
        answer++;
    }
    return answer;
}
